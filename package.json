{
  "name": "KelmaMobile",
  "version": "1.1.1",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:device": "node scripts/android-device.mjs run",
    "android:doctor": "node scripts/android-device.mjs doctor",
    "android:apk:debug": "node scripts/android-device.mjs apk:debug",
    "android:apk:release": "node scripts/android-device.mjs apk:release",
    "android:install:debug": "node scripts/android-device.mjs install:debug",
    "android:install:release": "node scripts/android-device.mjs install:release",
    "codegen:android": "react-native codegen --platform android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "rust:test": "cargo test --manifest-path rust/kelma-core/Cargo.toml"
  },
  "codegenConfig": {
    "name": "KelmaCoreSpec",
    "type": "modules",
    "jsSrcsDir": "specs",
    "android": {
      "javaPackageName": "com.kelmamobile.core"
    },
    "ios": {
      "modulesProvider": {
        "NativeKelmaCore": "RCTNativeKelmaCore",
        "NativeKelmaShare": "RCTNativeKelmaShare"
      }
    }
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.86.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-sound": "^0.13.0",
    "react-native-webview": "^14.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
